# ── REQUIRED ────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-a-long-random-secret

# Admin account created on first backend start (only if email not already in DB)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# SMTP — without these three vars Celery will fail to send emails
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your-google-app-password
SMTP_FROM_EMAIL=your.email@gmail.com

# ── OPTIONAL (defaults shown) ────────────────────────────────────────────────────
POSTGRES_DB=proxy
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ACTIVATION_KEY_BYTES=32

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Frontend → Backend URL (used at docker build time)
VITE_API_URL=http://localhost:8000
